font-family = JetBrainsMono Nerd Font
theme = TokyoNight Night
# theme = Atom One Light
# # cursor-color = #394260
# theme = tokyonight-day
#theme = nightfox
#theme = OneHalfDark
# theme = OneHalfLight
#theme = Atom
# theme = Github
# theme = GitHub-Dark-Colorblind
# theme = GitHub-Light-Colorblind
background = #0C0C0C
# background-opacity and blur break window rendering on WSLg
background-opacity = 0.8
# background = #F5F5F5
font-size = 18
keybind = ctrl+shift+up=scroll_page_up
keybind = ctrl+shift+down=scroll_page_down
keybind = alt+up=goto_split:top
keybind = alt+left=goto_split:left
keybind = alt+down=goto_split:bottom
keybind = alt+right=goto_split:right
keybind = ctrl+alt+shift+j=write_screen_file:open
command = /usr/bin/zsh
